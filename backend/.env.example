# ─────────────────────────────────────────────────────────────────────────────
# Aether Backend Environment Variables
# Copy this file to .env and fill in your values before deploying.
# ─────────────────────────────────────────────────────────────────────────────

# Server port (Azure App Service sets PORT automatically)
PORT=3000

# JWT signing secret — MUST be changed to a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=aether-change-this-to-a-long-random-secret-in-production

# The exact origin of your cPanel frontend (no trailing slash)
# e.g. https://yourdomain.com
# Set to * during local development only
FRONTEND_ORIGIN=http://localhost:3000

# ─── Future: Real Email Alerts ────────────────────────────────────────────────
# Uncomment and fill in when replacing the console.log mock with nodemailer
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# ALERT_FROM=alerts@yourdomain.com
# ALERT_TO=operations@yourdomain.com
